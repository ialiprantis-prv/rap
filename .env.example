# RAP (PRIVACT Risk Assessment Platform v4) — environment template.
# Copy to .env and fill in. No secrets are committed.

# --- backend (C2) ---
# PORT=8080
# HOST=0.0.0.0
# DATABASE_URL=file:./rap.db
# DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
# MIGRATIONS_DIR=./migrations

# --- auth / sessions (C3a) ---
# COOKIE_SECRET is REQUIRED (>=32 chars; the service fails closed without it).
# Generate with: openssl rand -base64 48
# COOKIE_SECRET=
# COOKIE_SECURE=true            # set false only for local http dev
# COOKIE_NAME=rap_session
# SESSION_ABSOLUTE_TTL_MS=28800000   # 8h
# SESSION_IDLE_TTL_MS=3600000        # 1h
# First-boot PRV super-admin seed (used only when the users table is empty):
# RAP_ADMIN_USERNAME=
# RAP_ADMIN_PASSWORD=               # min 12 chars

# --- login lockout (C3b) ---
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCK_BASE_MS=60000          # 1m, exponential backoff base
# LOGIN_LOCK_MAX_MS=900000          # 15m cap

# --- license (C3c) ---
# Path to the Ed25519-signed license file. Verified fail-closed at startup
# against the compiled-in production public key (NOT operator-overridable).
# LOGIN-style bypass is impossible: the verification key is not env-selectable.
# RAP_LICENSE_FILE=/etc/rap/license.json

# --- vulnerability sources (C4a; more sources land in C4b-d) ---
# NVD_API_KEY is a server-side secret (never logged); a key raises the rate limit.
# NVD_API_KEY=
# NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
# RAP_SOURCES_OFFLINE=false          # master kill switch for all source fetches
# RAP_SOURCE_NVD_ENABLED=true
# NVD_RATE_MAX=5                     # 50 with an API key
# NVD_RATE_WINDOW_MS=30000
# SOURCE_HTTP_TIMEOUT_MS=15000
# SOURCE_HTTP_RETRIES=3
# VULN_CACHE_TTL_NVD_MS=86400000     # 24h

# --- frontend (rung seeded later) ---
# VITE_API_BASE_URL=http://localhost:8080
